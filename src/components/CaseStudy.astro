---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const d = project.data;
const period = d.durationEnd ? `${d.durationStart}〜${d.durationEnd}` : d.durationStart;

const meta = [
  d.clientNameVisible && { label: 'クライアント', value: d.clientNameVisible },
  d.role && { label: '役割', value: d.role },
  { label: '期間', value: period },
  d.scope && { label: '規模・体制', value: d.scope },
].filter(Boolean) as Array<{ label: string; value: string }>;
---

<article class="case">
  <header class="case__head">
    <div class="case__tags">
      {d.industry.map((t) => <span class="case__tag">{t}</span>)}
      {
        d.confidentialityLevel !== 'Open' && (
          <span class="case__tag case__tag--nda">守秘義務に配慮し抽象化</span>
        )
      }
    </div>
    <h1 class="case__title">{d.title}</h1>
    <p class="case__summary">{d.summary}</p>

    <dl class="case__meta">
      {
        meta.map((m) => (
          <div class="case__meta-row">
            <dt>{m.label}</dt>
            <dd>{m.value}</dd>
          </div>
        ))
      }
    </dl>
  </header>

  {
    d.resultsQuantitative.length > 0 && (
      <ul class="case__highlights">
        {d.resultsQuantitative.slice(0, 3).map((r) => <li>{r}</li>)}
      </ul>
    )
  }

  <div class="case__body">
    <section class="case__block">
      <h2 class="case__block-title"><span class="case__block-no">01</span>課題</h2>
      <ul class="case__list">
        {d.challenge.map((c) => <li>{c}</li>)}
      </ul>
    </section>

    <section class="case__block">
      <h2 class="case__block-title"><span class="case__block-no">02</span>介入（実施したこと）</h2>
      <ul class="case__list">
        {d.intervention.map((c) => <li>{c}</li>)}
      </ul>
    </section>

    <section class="case__block case__block--result">
      <h2 class="case__block-title"><span class="case__block-no">03</span>成果</h2>
      <ul class="case__list case__list--quant">
        {d.resultsQuantitative.map((c) => <li>{c}</li>)}
      </ul>
      {
        d.resultsQualitative.length > 0 && (
          <ul class="case__list case__list--qual">
            {d.resultsQualitative.map((c) => <li>{c}</li>)}
          </ul>
        )
      }
    </section>

    {
      d.toolsMethods.length > 0 && (
        <section class="case__block">
          <h2 class="case__block-title"><span class="case__block-no">04</span>使用手法・ツール</h2>
          <div class="case__chips">
            {d.toolsMethods.map((t) => <span class="case__chip">{t}</span>)}
          </div>
        </section>
      )
    }

    {d.note && <p class="case__note">{d.note}</p>}
  </div>
</article>

<style>
  .case {
    display: grid;
    gap: 2.5rem;
  }

  .case__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .case__tag {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--color-primary);
    background: var(--color-primary-50);
    padding: 0.25rem 0.7rem;
    border-radius: 9999px;
  }

  .case__tag--nda {
    color: var(--color-accent);
    background: var(--color-accent-soft);
  }

  .case__title {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    line-height: 1.45;
    margin: 0;
  }

  .case__summary {
    margin: 1.25rem 0 0;
    font-size: 1.05rem;
    line-height: 1.9;
    color: var(--color-ink-soft);
  }

  .case__meta {
    margin: 2rem 0 0;
    display: grid;
    gap: 0;
    border-top: 1px solid var(--color-rule);
  }

  .case__meta-row {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 1rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--color-rule);
  }

  .case__meta-row dt {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.04em;
  }

  .case__meta-row dd {
    margin: 0;
    font-size: 0.92rem;
    color: var(--color-ink);
    line-height: 1.7;
  }

  .case__highlights {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.75rem;
  }

  .case__highlights li {
    font-size: 0.85rem;
    font-weight: 700;
    line-height: 1.6;
    color: var(--color-ink);
    padding: 0.85rem 1rem;
    background: var(--color-primary-50);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 6px 6px 0;
  }

  .case__body {
    display: grid;
    gap: 2rem;
  }

  .case__block-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.25rem;
    margin: 0 0 1rem;
  }

  .case__block-no {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 800;
    color: white;
    background: var(--color-primary);
    width: 2rem;
    height: 2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    letter-spacing: 0.02em;
  }

  .case__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }

  .case__list li {
    position: relative;
    padding-left: 1.5rem;
    line-height: 1.85;
    color: var(--color-ink);
  }

  .case__list li::before {
    content: '';
    position: absolute;
    left: 0.1rem;
    top: 0.7rem;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--color-primary-300);
  }

  .case__block--result {
    background: var(--color-primary-50);
    border-radius: var(--radius-card);
    padding: 1.75rem;
  }

  .case__list--quant li {
    font-weight: 700;
  }

  .case__list--quant li::before {
    background: var(--color-accent);
    width: 0.6rem;
    height: 0.6rem;
    top: 0.65rem;
    left: 0.05rem;
  }

  .case__list--qual {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px dashed var(--color-primary-200);
  }

  .case__list--qual li {
    color: var(--color-ink-soft);
    font-weight: 400;
  }

  .case__list--qual li::before {
    background: var(--color-primary-200);
  }

  .case__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .case__chip {
    font-size: 0.82rem;
    color: var(--color-ink);
    background: var(--color-paper-soft);
    border: 1px solid var(--color-rule);
    padding: 0.35rem 0.85rem;
    border-radius: 9999px;
  }

  .case__note {
    font-size: 0.85rem;
    color: var(--color-ink-soft);
    line-height: 1.8;
    padding: 1rem 1.25rem;
    background: var(--color-paper-soft);
    border-radius: 0.75rem;
    margin: 0;
  }

  @media (max-width: 600px) {
    .case__meta-row {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
