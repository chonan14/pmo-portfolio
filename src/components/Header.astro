---
import { PROFILE, NAV } from '@/consts';
---

<header class="site-header">
  <div class="container-wide site-header__inner">
    <a href="/" class="site-header__brand" aria-label={`${PROFILE.fullName} トップページ`}>
      <span class="site-header__brand-name">{PROFILE.fullName}</span>
      <span class="site-header__brand-meta">統括PMO ／ 戦略PMO</span>
    </a>

    <nav aria-label="グローバルナビゲーション" class="site-header__nav">
      <button
        type="button"
        class="site-header__menu-toggle"
        aria-controls="primary-nav"
        aria-expanded="false"
        data-menu-toggle
      >
        <span class="site-header__menu-toggle-bar" aria-hidden="true"></span>
        <span class="site-header__menu-toggle-bar" aria-hidden="true"></span>
        <span class="site-header__menu-toggle-bar" aria-hidden="true"></span>
        <span class="sr-only">メニューを開く</span>
      </button>
      <ul id="primary-nav" class="site-header__list" data-menu-list>
        {
          NAV.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  'site-header__link',
                  item.emphasized && 'site-header__link--emphasized',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-bg-deep) 72%, transparent);
    backdrop-filter: saturate(160%) blur(14px);
    border-bottom: 1px solid var(--color-rule);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4rem;
    padding-block: 0.75rem;
  }

  .site-header__brand {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    text-decoration: none;
    line-height: 1.35;
  }

  .site-header__brand-name {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.125rem;
    color: var(--color-ink);
    letter-spacing: 0.06em;
  }

  .site-header__brand-meta {
    font-size: 0.7rem;
    color: var(--color-ink-soft);
    letter-spacing: 0.14em;
  }

  .site-header__nav {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .site-header__list {
    display: flex;
    align-items: center;
    gap: 0.15rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-header__link {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.8rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    color: var(--color-ink);
    text-decoration: none;
    border-radius: 9999px;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .site-header__link:hover {
    background: var(--color-primary-50);
    color: var(--color-primary);
  }

  .site-header__link--emphasized {
    background: var(--color-primary);
    color: white;
    padding-inline: 1.25rem;
  }

  .site-header__link--emphasized:hover {
    background: var(--color-primary-700);
    color: white;
  }

  .site-header__menu-toggle {
    display: none;
    background: transparent;
    border: 0;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    cursor: pointer;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    border-radius: 0.5rem;
  }

  .site-header__menu-toggle-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-primary);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .site-header__menu-toggle[aria-expanded='true'] .site-header__menu-toggle-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .site-header__menu-toggle[aria-expanded='true'] .site-header__menu-toggle-bar:nth-child(2) {
    opacity: 0;
  }
  .site-header__menu-toggle[aria-expanded='true'] .site-header__menu-toggle-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 1020px) {
    .site-header__menu-toggle {
      display: flex;
    }

    .site-header__list {
      position: absolute;
      inset: 4rem 0 auto 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0.25rem;
      padding: 1rem 1.25rem 1.5rem;
      background: var(--color-paper);
      border-bottom: 1px solid var(--color-rule);
      box-shadow: var(--shadow-soft);
      transform: translateY(-100%);
      opacity: 0;
      pointer-events: none;
      transition: transform 0.2s ease, opacity 0.2s ease;
    }

    .site-header__list[data-open='true'] {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }

    .site-header__link {
      padding: 0.875rem 1rem;
      justify-content: center;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const list = document.querySelector<HTMLUListElement>('[data-menu-list]');

  if (toggle && list) {
    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!isOpen));
      list.dataset.open = String(!isOpen);
    });

    list.addEventListener('click', (event) => {
      if ((event.target as HTMLElement).closest('a')) {
        toggle.setAttribute('aria-expanded', 'false');
        list.dataset.open = 'false';
      }
    });
  }
</script>
