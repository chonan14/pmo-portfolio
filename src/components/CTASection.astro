---
import { AVAILABILITY } from '@/consts';

interface Props {
  heading?: string;
  text?: string;
}

const {
  heading = 'プロジェクトの「決まらない」を、動かします。',
  text = '統括PMO・戦略PMO・クライシスマネジメントのご相談を承ります。現状の課題感だけでも構いません。初回相談は無料です。',
} = Astro.props;
---

<section class="cta">
  <div class="container-default cta__inner">
    <p class="section-eyebrow cta__eyebrow">Contact</p>
    <h2 class="cta__title">{heading}</h2>
    <p class="cta__text">{text}</p>

    <ul class="cta__availability">
      <li><span>稼働</span>{AVAILABILITY.days}</li>
      <li><span>形態</span>{AVAILABILITY.location}</li>
      <li><span>受入</span>{AVAILABILITY.start}</li>
    </ul>

    <div class="cta__actions">
      <a href="/contact/" class="btn-primary">相談・お見積りをする</a>
      <a href="/projects/" class="btn-ghost cta__ghost">実績を見る</a>
    </div>
  </div>
</section>

<style>
  .cta {
    background: linear-gradient(135deg, var(--color-primary-800), var(--color-primary-900));
    color: white;
    border-radius: var(--radius-card);
    margin-inline: auto;
    max-width: var(--container-wide);
  }

  .cta__inner {
    padding-block: clamp(2.5rem, 6vw, 4rem);
    text-align: center;
  }

  .cta__eyebrow {
    color: var(--color-accent);
    justify-content: center;
  }

  .cta__eyebrow::before {
    background: var(--color-accent);
  }

  .cta__title {
    margin: 1rem 0 0;
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    color: white;
    line-height: 1.5;
  }

  .cta__text {
    margin: 1.25rem auto 0;
    max-width: 40rem;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.9;
  }

  .cta__availability {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .cta__availability li {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 700;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.16);
    padding: 0.5rem 1rem;
    border-radius: 9999px;
  }

  .cta__availability span {
    color: var(--color-accent);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
  }

  .cta__actions {
    margin-top: 2.25rem;
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta__ghost {
    color: white;
    border-color: rgba(255, 255, 255, 0.5);
  }

  .cta__ghost:hover {
    background: white;
    color: var(--color-primary);
  }
</style>
