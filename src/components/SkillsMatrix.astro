---
import { SKILL_GROUPS } from '@/consts';

const levelClass = (l: string): string =>
  l === '◎' ? 'main' : l === '○' ? 'exp' : 'sub';
---

<div class="smx">
  <div class="smx__groups">
    {
      SKILL_GROUPS.map((g) => (
        <div class="smx__group">
          <h3 class="smx__title">{g.title}</h3>
          <ul class="smx__list">
            {g.items.map((it) => (
              <li class="smx__item">
                <span class:list={['smx__level', `smx__level--${levelClass(it.level)}`]}>
                  {it.level}
                </span>
                <span class="smx__label">{it.label}</span>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
  <p class="smx__legend"><span>◎ 主担当</span><span>○ 経験あり</span><span>△ 補佐</span></p>
</div>

<style>
  .smx {
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-card);
    background: var(--color-paper);
    padding: 1.75rem;
    box-shadow: var(--shadow-soft);
  }

  .smx__groups {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .smx__title {
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    padding-bottom: 0.6rem;
    margin: 0 0 1rem;
    border-bottom: 2px solid var(--color-primary-100);
  }

  .smx__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }

  .smx__item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .smx__level {
    flex-shrink: 0;
    width: 1.6rem;
    height: 1.6rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .smx__level--main {
    color: white;
    background: var(--color-primary);
  }

  .smx__level--exp {
    color: var(--color-primary);
    background: var(--color-primary-100);
  }

  .smx__level--sub {
    color: var(--color-ink-soft);
    background: var(--color-paper-soft);
    border: 1px solid var(--color-rule);
  }

  .smx__label {
    font-size: 0.92rem;
    color: var(--color-ink);
  }

  .smx__legend {
    margin: 1.5rem 0 0;
    padding-top: 1rem;
    border-top: 1px solid var(--color-rule);
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    font-size: 0.78rem;
    color: var(--color-ink-soft);
  }

  @media (max-width: 640px) {
    .smx__groups {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
