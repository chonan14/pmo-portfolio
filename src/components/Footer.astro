---
import { PROFILE, FOOTER_LINKS, SITE } from '@/consts';
const year = new Date().getFullYear();
const updated = new Date().toISOString().slice(0, 7).replace('-', '.');
---

<footer class="site-footer">
  <div class="container-wide site-footer__inner">
    <div class="site-footer__brand">
      <p class="site-footer__name">{PROFILE.fullName}</p>
      <p class="site-footer__meta">{PROFILE.title}</p>
      <p class="site-footer__contact">
        <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      </p>
      <p class="site-footer__pdf">
        <a href="/chonan-takanori-resume.pdf">職務経歴書（PDF）をダウンロード</a>
      </p>
    </div>

    <nav class="site-footer__nav" aria-label="ページ">
      <p class="site-footer__nav-title">ページ</p>
      <ul>
        {FOOTER_LINKS.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
    </nav>
  </div>

  <div class="site-footer__bottom">
    <div class="container-wide site-footer__bottom-inner">
      <small>&copy; {year} {PROFILE.fullName}</small>
      <small>最終更新 {updated}</small>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 6rem;
    background: var(--color-primary-900);
    color: rgba(255, 255, 255, 0.84);
  }

  .site-footer__inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 2.5rem;
    padding-block: 3.25rem;
  }

  .site-footer__name {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 800;
    color: white;
    margin: 0;
  }

  .site-footer__meta {
    margin: 0.5rem 0 0;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.04em;
  }

  .site-footer__contact {
    margin: 1.25rem 0 0;
  }

  .site-footer__contact a,
  .site-footer__pdf a {
    color: var(--color-accent);
    text-decoration: none;
    font-size: 0.9rem;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s ease;
  }

  .site-footer__contact a:hover,
  .site-footer__pdf a:hover {
    border-color: var(--color-accent);
  }

  .site-footer__pdf {
    margin: 0.5rem 0 0;
  }

  .site-footer__nav-title {
    margin: 0 0 1rem 0;
    color: white;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.12em;
  }

  .site-footer__nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.55rem;
  }

  .site-footer__nav a {
    color: rgba(255, 255, 255, 0.84);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.15s ease;
  }

  .site-footer__nav a:hover {
    color: white;
  }

  .site-footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .site-footer__bottom-inner {
    padding-block: 1.1rem;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.78rem;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 720px) {
    .site-footer__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding-block: 2.5rem;
    }
    .site-footer {
      margin-top: 4rem;
    }
  }
</style>
