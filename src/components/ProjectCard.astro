---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const d = project.data;
const period = d.durationEnd ? `${d.durationStart}〜${d.durationEnd}` : d.durationStart;
const topResult = d.resultsQuantitative[0];
---

<article class="pcard">
  <a href={`/projects/${d.slug}/`} class="pcard__link">
    <div class="pcard__head">
      <div class="pcard__tags">
        {d.industry.map((t) => <span class="pcard__tag">{t}</span>)}
        {
          d.confidentialityLevel !== 'Open' && (
            <span class="pcard__tag pcard__tag--nda">守秘配慮</span>
          )
        }
      </div>
      <span class="pcard__period">{period}</span>
    </div>

    <h3 class="pcard__title">{d.title}</h3>
    <p class="pcard__summary">{d.summary}</p>

    {
      topResult && (
        <p class="pcard__result">
          <span class="pcard__result-label">成果</span>
          {topResult}
        </p>
      )
    }

    <div class="pcard__foot">
      <span class="pcard__role">{d.role}</span>
      <span class="pcard__more">ケースを読む →</span>
    </div>
  </a>
</article>

<style>
  .pcard {
    height: 100%;
  }

  .pcard__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: 0.75rem;
    padding: 1.5rem;
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-card);
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow-soft);
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }

  .pcard__link:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-card);
    border-color: var(--color-primary-200);
  }

  .pcard__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .pcard__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .pcard__tag {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--color-primary);
    background: var(--color-primary-50);
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
  }

  .pcard__tag--nda {
    color: var(--color-accent);
    background: var(--color-accent-soft);
  }

  .pcard__period {
    flex-shrink: 0;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-ink-soft);
    letter-spacing: 0.04em;
  }

  .pcard__title {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.5;
    color: var(--color-primary);
  }

  .pcard__summary {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--color-ink-soft);
  }

  .pcard__result {
    margin: 0;
    font-size: 0.85rem;
    font-weight: 700;
    line-height: 1.7;
    color: var(--color-ink);
    padding: 0.75rem 0.9rem;
    background: var(--color-paper-soft);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 0.5rem 0.5rem 0;
  }

  .pcard__result-label {
    display: inline-block;
    margin-right: 0.5rem;
    font-size: 0.7rem;
    color: var(--color-accent);
    letter-spacing: 0.08em;
  }

  .pcard__foot {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding-top: 0.5rem;
  }

  .pcard__role {
    font-size: 0.78rem;
    color: var(--color-ink-soft);
  }

  .pcard__more {
    flex-shrink: 0;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-primary);
  }
</style>
