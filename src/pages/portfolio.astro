---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTASection from '@/components/CTASection.astro';
import { getCollection } from 'astro:content';

const items = (await getCollection('portfolio'))
  .filter((p) => p.data.status === 'Public')
  .sort((a, b) => b.data.displayOrder - a.data.displayOrder);
---

<BaseLayout
  title="ポートフォリオ"
  description="自作のWebサービス・ツール群。Astro・Cloudflare・生成AIなどを用い、企画から実装・運用までを一貫して手がけた成果物。「技術が分かるPM」であることの証明。"
>
  <section class="page-head">
    <div class="container-wide">
      <p class="section-eyebrow">Portfolio</p>
      <h1 class="page-head__title">ポートフォリオ</h1>
      <p class="page-head__lead">
        企画から実装・運用までを自ら手がけた成果物です。開発チームと同じ言語で話せる「技術が分かるPM」であることの証明として掲載しています。
      </p>
    </div>
  </section>

  <section class="page-section">
    <div class="container-wide">
      <div class="grid">
        {
          items.map((item) => {
            const d = item.data;
            return (
              <article class="wcard">
                <div class="wcard__tags">
                  {d.type.map((t) => (
                    <span class="wcard__tag">{t}</span>
                  ))}
                  {d.category && <span class="wcard__tag wcard__tag--cat">{d.category}</span>}
                </div>
                <h2 class="wcard__title">
                  {d.url ? (
                    <a href={d.url} target="_blank" rel="noopener noreferrer">
                      {d.title}
                    </a>
                  ) : (
                    d.title
                  )}
                </h2>
                <p class="wcard__desc">{d.description}</p>
                {d.keyMetrics.length > 0 && (
                  <ul class="wcard__metrics">
                    {d.keyMetrics.map((m) => (
                      <li>{m}</li>
                    ))}
                  </ul>
                )}
                {d.techStack.length > 0 && (
                  <div class="wcard__stack">
                    {d.techStack.map((t) => (
                      <span class="wcard__chip">{t}</span>
                    ))}
                  </div>
                )}
                {d.url && (
                  <a class="wcard__link" href={d.url} target="_blank" rel="noopener noreferrer">
                    サイトを見る →
                  </a>
                )}
              </article>
            );
          })
        }
      </div>
    </div>
  </section>

  <div class="container-wide cta-wrap">
    <CTASection />
  </div>
</BaseLayout>

<style>
  .page-head {
    background: linear-gradient(180deg, var(--color-primary-50), var(--color-paper));
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }

  .page-head__title {
    margin: 1rem 0 0;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
  }

  .page-head__lead {
    margin: 1.25rem 0 0;
    max-width: 44rem;
    color: var(--color-ink-soft);
    line-height: 1.9;
  }

  .page-section {
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .wcard {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem;
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
  }

  .wcard__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .wcard__tag {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-primary);
    background: var(--color-primary-50);
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
  }

  .wcard__tag--cat {
    color: var(--color-accent);
    background: var(--color-accent-soft);
  }

  .wcard__title {
    margin: 0;
    font-size: 1.15rem;
    color: var(--color-primary);
  }

  .wcard__title a {
    text-decoration: none;
  }

  .wcard__title a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .wcard__desc {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.85;
    color: var(--color-ink-soft);
  }

  .wcard__metrics {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.3rem;
  }

  .wcard__metrics li {
    position: relative;
    padding-left: 1rem;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-ink);
  }

  .wcard__metrics li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6rem;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: var(--color-accent);
  }

  .wcard__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .wcard__chip {
    font-size: 0.75rem;
    color: var(--color-ink-soft);
    background: var(--color-paper-soft);
    border: 1px solid var(--color-rule);
    padding: 0.25rem 0.6rem;
    border-radius: 0.4rem;
  }

  .wcard__link {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
  }

  .cta-wrap {
    margin-bottom: clamp(3rem, 8vw, 6rem);
  }

  @media (max-width: 960px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 720px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
