---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .filter((p) => p.data.status === 'Public')
  .sort((a, b) => b.data.displayOrder - a.data.displayOrder);
---

<BaseLayout
  title="実績・ケーススタディ"
  description="統括PMO・戦略PMO・クライシスマネジメントの実績一覧。課題→介入→成果の3段で、国家インフラ規模から危機対応・官民連携までのプロジェクトを掲載。"
>
  <section class="page-head">
    <div class="container-wide">
      <p class="section-eyebrow">Case Studies</p>
      <h1 class="page-head__title">実績・ケーススタディ</h1>
      <p class="page-head__lead">
        各案件を「課題 → 介入（実施したこと） → 成果」の3段で整理しています。通信・金融・公共（自治体DX）から、危機対応・官民連携まで。
      </p>
    </div>
  </section>

  <section class="page-section">
    <div class="container-wide">
      <div class="ptable-wrap">
        <h2 class="ptable-title">案件一覧</h2>
        <table class="ptable">
          <thead>
            <tr><th>案件</th><th>業界・領域</th><th>役割</th><th>期間</th></tr>
          </thead>
          <tbody>
            {
              projects.map((p) => (
                <tr>
                  <td class="ptable__name">
                    <a href={`/projects/${p.data.slug}/`}>{p.data.title}</a>
                  </td>
                  <td>{p.data.industry.join('・')}</td>
                  <td>{p.data.role}</td>
                  <td class="ptable__period">
                    {p.data.durationEnd
                      ? `${p.data.durationStart}〜${p.data.durationEnd}`
                      : p.data.durationStart}
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>

      <div class="cards">
        {projects.map((p) => <ProjectCard project={p} />)}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .page-head {
    background: linear-gradient(180deg, var(--color-primary-50), var(--color-paper));
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }

  .page-head__title {
    margin: 1rem 0 0;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
  }

  .page-head__lead {
    margin: 1.25rem 0 0;
    max-width: 44rem;
    color: var(--color-ink-soft);
    line-height: 1.9;
  }

  .page-section {
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }

  .ptable-wrap {
    margin-bottom: 3rem;
    overflow-x: auto;
  }

  .ptable-title {
    font-size: 1.1rem;
    margin: 0 0 1rem;
  }

  .ptable {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }

  .ptable th,
  .ptable td {
    text-align: left;
    padding: 0.7rem 0.9rem;
    border-bottom: 1px solid var(--color-rule);
    vertical-align: top;
  }

  .ptable thead th {
    color: var(--color-primary);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    border-bottom: 2px solid var(--color-primary-100);
    white-space: nowrap;
  }

  .ptable__name a {
    color: var(--color-primary);
    font-weight: 700;
    text-decoration: none;
  }

  .ptable__name a:hover {
    text-decoration: underline;
  }

  .ptable__period {
    white-space: nowrap;
    color: var(--color-ink-soft);
  }

  .ptable tbody tr:hover {
    background: var(--color-paper-soft);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .cta-wrap {
    margin-bottom: clamp(3rem, 8vw, 6rem);
  }

  @media (max-width: 960px) {
    .cards {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 720px) {
    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>
