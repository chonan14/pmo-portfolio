---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CareerTimeline from '@/components/CareerTimeline.astro';
import CTASection from '@/components/CTASection.astro';
import { getCollection } from 'astro:content';

const all = (await getCollection('career')).filter((c) => c.data.status === 'Public');
const byType = (t: string) =>
  all
    .filter((c) => c.data.type === t)
    .sort((a, b) => b.data.displayOrder - a.data.displayOrder);

const employment = byType('Employment');
const committee = byType('Committee');
const education = byType('Education');

const skillSummary: Array<{ label: string; value: string }> = [
  { label: 'PMO実務', value: '約10年（統括PMO／戦略PMO／リードPMO／管理PMO）' },
  { label: '最大案件', value: '開発予算1兆円 ／ 体制2,000人 ／ 期間18ヶ月（LTE全国展開）' },
  { label: '対応業界', value: '通信・金融・公共（自治体DX）／ 業界不問で対応可' },
  { label: '官公庁実績', value: '総務省・経済産業省・IPA・デジタル庁との直接協働' },
  {
    label: '強み領域',
    value:
      '統括PMO統制 ／ CxO向けレポーティング ／ マルチベンダーコントロール ／ クライシスマネジメント ／ 合意形成・ルールメイキング',
  },
  { label: '使用ツール', value: 'MS Office ／ Slack ／ Backlog ／ Confluence ／ MS Teams ／ Notion' },
];
---

<BaseLayout
  title="職務経歴"
  description="長南貴則の職務経歴。NTTドコモでの統括PMO／戦略PMO（2007〜2026）、フリーランスPMO、IPA専門委員・デジタル庁デジタル推進委員、政策学修士。"
>
  <section class="page-head">
    <div class="container-default">
      <p class="section-eyebrow">Career</p>
      <h1 class="page-head__title">職務経歴</h1>
      <p class="page-head__lead">
        NTTドコモにて約16年、統括PMO／戦略PMOとして全社横断システム導入・DX推進・危機対応に従事。以降フリーランスPMOとして大手事業会社のIT部門を支援。IPA・デジタル庁の委員として国のガイドライン策定にも参画しています。
      </p>
    </div>
  </section>

  <section class="page-section">
    <div class="container-default">
      <div class="skills">
        <h2 class="skills__title">PMOスキルサマリー</h2>
        <dl class="skills__list">
          {
            skillSummary.map((s) => (
              <div class="skills__row">
                <dt>{s.label}</dt>
                <dd>{s.value}</dd>
              </div>
            ))
          }
        </dl>
      </div>

      <CareerTimeline title="職歴" entries={employment} />
      <CareerTimeline title="委員・外部活動" entries={committee} />
      <CareerTimeline title="学歴" entries={education} />
    </div>
  </section>

  <div class="container-wide cta-wrap">
    <CTASection />
  </div>
</BaseLayout>

<style>
  .page-head {
    background: linear-gradient(180deg, var(--color-primary-50), var(--color-paper));
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }

  .page-head__title {
    margin: 1rem 0 0;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
  }

  .page-head__lead {
    margin: 1.25rem 0 0;
    color: var(--color-ink-soft);
    line-height: 1.95;
  }

  .page-section {
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }

  .skills {
    margin-bottom: 3.5rem;
    padding: 1.75rem;
    background: var(--color-paper-soft);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-card);
  }

  .skills__title {
    margin: 0 0 1.25rem;
    font-size: 1.2rem;
  }

  .skills__list {
    margin: 0;
    display: grid;
    gap: 0;
  }

  .skills__row {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 1rem;
    padding: 0.75rem 0;
    border-top: 1px solid var(--color-rule);
  }

  .skills__row:first-child {
    border-top: none;
  }

  .skills__row dt {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .skills__row dd {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--color-ink);
  }

  .cta-wrap {
    margin-bottom: clamp(3rem, 8vw, 6rem);
  }

  @media (max-width: 600px) {
    .skills__row {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
