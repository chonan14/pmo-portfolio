---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CareerTimeline from '@/components/CareerTimeline.astro';
import SkillsMatrix from '@/components/SkillsMatrix.astro';
import { getCollection } from 'astro:content';
import { TOOLS } from '@/consts';

const all = (await getCollection('career')).filter((c) => c.data.status === 'Public');
const byType = (t: string) =>
  all
    .filter((c) => c.data.type === t)
    .sort((a, b) => b.data.displayOrder - a.data.displayOrder);

const employment = byType('Employment');
const committee = byType('Committee');
const education = byType('Education');

const summary: Array<{ label: string; value: string }> = [
  { label: 'PMO実務', value: '約10年（統括PMO／戦略PMO／リードPMO／管理PMO）' },
  { label: '最大案件', value: '開発予算1兆円 ／ 体制2,000人 ／ 期間18ヶ月（LTE全国展開）' },
  { label: '対応業界', value: '通信・金融・公共（自治体DX）／ 業界不問で対応可' },
  { label: '官公庁実績', value: '総務省・経済産業省・IPA・デジタル庁との直接協働' },
  { label: '使用ツール', value: TOOLS.join(' ／ ') },
];
---

<BaseLayout
  title="職務経歴"
  description="長南貴則の職務経歴。NTTドコモでの統括PMO／戦略PMO（2007〜2023・約16年）、フリーランスPMO、IPA専門委員・デジタル庁デジタル推進委員、政策学修士。"
>
  <section class="page-head">
    <div class="container-default">
      <p class="section-eyebrow">Career</p>
      <h1 class="page-head__title">職務経歴</h1>
      <p class="page-head__lead">
        NTTドコモにて約16年、統括PMO／戦略PMOとして全社横断システム導入・DX推進・危機対応に従事。以降フリーランスPMOとして大手事業会社のIT部門を支援。IPA・デジタル庁の委員として国のガイドライン策定にも参画しています。
      </p>
    </div>
  </section>

  <section class="page-section">
    <div class="container-default">
      <div class="block">
        <h2 class="block__title">PMOスキルサマリー</h2>
        <dl class="summary">
          {
            summary.map((s) => (
              <div class="summary__row">
                <dt>{s.label}</dt>
                <dd>{s.value}</dd>
              </div>
            ))
          }
        </dl>
      </div>

      <div class="block">
        <h2 class="block__title">スキル・コンピテンシー</h2>
        <SkillsMatrix />
      </div>

      <CareerTimeline title="職歴" entries={employment} />
      <CareerTimeline title="委員・外部活動" entries={committee} />
      <CareerTimeline title="学歴" entries={education} />
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    background: linear-gradient(180deg, var(--color-primary-50), var(--color-paper));
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }

  .page-head__title {
    margin: 1rem 0 0;
    font-size: clamp(1.9rem, 4vw, 2.6rem);
  }

  .page-head__lead {
    margin: 1.25rem 0 0;
    color: var(--color-ink-soft);
    line-height: 2;
  }

  .page-section {
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }

  .block {
    margin-bottom: 3rem;
  }

  .block__title {
    font-size: 1.2rem;
    margin: 0 0 1.25rem;
  }

  .summary {
    margin: 0;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-card);
    overflow: hidden;
  }

  .summary__row {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 1rem;
    padding: 0.85rem 1.25rem;
    border-top: 1px solid var(--color-rule);
  }

  .summary__row:first-child {
    border-top: none;
  }

  .summary__row dt {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .summary__row dd {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--color-ink);
  }

  @media (max-width: 600px) {
    .summary__row {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
