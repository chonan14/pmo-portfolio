---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { PROFILE, AVAILABILITY } from '@/consts';

const subject = encodeURIComponent('PMO支援のご相談');
const body = encodeURIComponent(
  [
    `${PROFILE.fullName} 様`,
    '',
    '以下についてご相談したくご連絡いたしました。',
    '',
    '・会社名／ご担当者名：',
    '・ご相談内容（現状の課題感）：',
    '・想定時期／稼働量：',
    '・ご予算感：',
    '',
  ].join('\n'),
);
const mailto = `mailto:${PROFILE.email}?subject=${subject}&body=${body}`;

const intake = [
  '会社名・ご担当者名',
  'ご相談内容（現状の課題感だけでもOK）',
  '想定の時期・稼働量（例：週2〜3日／3ヶ月〜）',
  'ご予算感（目安で構いません）',
];
---

<BaseLayout
  title="お問い合わせ"
  description="PMO支援のご相談・お見積りのお問い合わせ。週3〜4日・フルリモート優先で、2026年5月以降の案件を受付中。初回相談は無料です。"
>
  <section class="page-head">
    <div class="container-narrow">
      <p class="section-eyebrow">Contact</p>
      <h1 class="page-head__title">お問い合わせ</h1>
      <p class="page-head__lead">
        統括PMO・戦略PMO・クライシスマネジメントのご相談を承ります。現状の課題感だけでも構いません。初回相談は無料です。
      </p>
    </div>
  </section>

  <section class="page-section">
    <div class="container-narrow">
      <div class="contact-grid">
        <div class="contact-main">
          <h2 class="contact-h2">ご相談・お見積り</h2>
          <p class="contact-text">
            下のボタンからメールでご連絡ください。いただいた内容をもとに、初回（無料）のオンライン面談を調整いたします。
          </p>
          <a href={mailto} class="btn-primary contact-btn">メールで相談する</a>
          <p class="contact-note">
            ※ Webからの送信フォームは現在準備中です（公開時に設置予定）。それまではメールにて承ります。
          </p>
        </div>

        <aside class="contact-side">
          <div class="card">
            <h3 class="card__title">稼働条件</h3>
            <dl class="card__dl">
              <div><dt>稼働</dt><dd>{AVAILABILITY.days}</dd></div>
              <div><dt>形態</dt><dd>{AVAILABILITY.location}</dd></div>
              <div><dt>受入</dt><dd>{AVAILABILITY.start}</dd></div>
            </dl>
          </div>

          <div class="card">
            <h3 class="card__title">いただきたい情報</h3>
            <ul class="card__list">
              {intake.map((i) => <li>{i}</li>)}
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    background: linear-gradient(180deg, var(--color-primary-50), var(--color-paper));
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }

  .page-head__title {
    margin: 1rem 0 0;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
  }

  .page-head__lead {
    margin: 1.25rem 0 0;
    color: var(--color-ink-soft);
    line-height: 1.9;
  }

  .page-section {
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  .contact-h2 {
    font-size: 1.3rem;
    margin: 0 0 1rem;
  }

  .contact-text {
    margin: 0 0 1.5rem;
    line-height: 1.95;
    color: var(--color-ink-soft);
  }

  .contact-btn {
    font-size: 1.05rem;
    padding: 1rem 2rem;
  }

  .contact-note {
    margin: 1.25rem 0 0;
    font-size: 0.82rem;
    color: var(--color-ink-soft);
    line-height: 1.8;
  }

  .contact-side {
    display: grid;
    gap: 1.25rem;
  }

  .card {
    padding: 1.5rem;
    background: var(--color-paper-soft);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-card);
  }

  .card__title {
    margin: 0 0 1rem;
    font-size: 1rem;
  }

  .card__dl {
    margin: 0;
    display: grid;
    gap: 0.6rem;
  }

  .card__dl div {
    display: flex;
    gap: 0.75rem;
    font-size: 0.9rem;
  }

  .card__dl dt {
    flex-shrink: 0;
    width: 2.5rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .card__dl dd {
    margin: 0;
    color: var(--color-ink);
  }

  .card__list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.55rem;
  }

  .card__list li {
    position: relative;
    padding-left: 1.1rem;
    font-size: 0.88rem;
    line-height: 1.7;
    color: var(--color-ink);
  }

  .card__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6rem;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: var(--color-accent);
  }

  @media (max-width: 760px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
