---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { PROFILE, SITE } from '@/consts';

const sections: Array<{ h: string; body: string }> = [
  {
    h: '1. 本サイトについて',
    body: '本サイトは、長南 貴則の個人的な職務経歴・実績をまとめたキャリア・ポートフォリオであり、情報提供を目的としています。商品・サービスの販売や申込みの受付は行っていません。',
  },
  {
    h: '2. 取得する個人情報',
    body: 'お問い合わせ（メール）をいただいた場合に、送信者のお名前・メールアドレス・ご連絡内容を取得します。本サイトの閲覧のみでは、個人情報を取得しません。',
  },
  {
    h: '3. 利用目的',
    body: '取得した個人情報は、お問い合わせへの対応・ご連絡のためにのみ利用します。これ以外の目的には利用しません。',
  },
  {
    h: '4. 第三者への提供',
    body: '法令に基づく場合を除き、ご本人の同意なく個人情報を第三者へ提供することはありません。',
  },
  {
    h: '5. アクセス解析・Cookie',
    body: '本サイトは、アクセス解析ツールや広告・トラッキング目的のCookieを使用していません。',
  },
  {
    h: '6. 管理',
    body: '取得した個人情報は適切に管理し、利用目的の達成後は速やかに、かつ適切に廃棄します。',
  },
  {
    h: '7. 開示・訂正・削除等',
    body: 'ご本人からの個人情報の開示・訂正・削除等のご要望には、下記の窓口にて適切に対応します。',
  },
  {
    h: '8. 改定',
    body: '本ポリシーは、必要に応じて改定することがあります。改定後の内容は本ページに掲載します。',
  },
];
---

<BaseLayout title="プライバシーポリシー" description="本サイトのプライバシーポリシー（個人情報の取り扱い）。">
  <section class="page-head">
    <div class="container-narrow">
      <p class="section-eyebrow">Privacy</p>
      <h1 class="page-head__title">プライバシーポリシー</h1>
    </div>
  </section>

  <section class="page-section">
    <div class="container-narrow prose">
      {
        sections.map((s) => (
          <div class="pp">
            <h2>{s.h}</h2>
            <p>{s.body}</p>
          </div>
        ))
      }

      <div class="pp">
        <h2>9. 運営者・お問い合わせ窓口</h2>
        <p>
          運営者：{PROFILE.fullName}<br />
          連絡先：<a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        </p>
      </div>

      <p class="pp__date">制定日：2026年6月</p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    background: linear-gradient(180deg, var(--color-primary-50), var(--color-paper));
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }

  .page-head__title {
    margin: 1rem 0 0;
    font-size: clamp(1.8rem, 4vw, 2.4rem);
  }

  .page-section {
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }

  .pp {
    margin-bottom: 1.75rem;
  }

  .pp h2 {
    font-size: 1.05rem;
    color: var(--color-primary);
    margin: 0 0 0.5rem;
  }

  .pp p {
    margin: 0;
    line-height: 1.95;
    color: var(--color-ink);
  }

  .pp a {
    color: var(--color-primary-500);
  }

  .pp__date {
    margin-top: 2rem;
    font-size: 0.85rem;
    color: var(--color-ink-soft);
  }
</style>
