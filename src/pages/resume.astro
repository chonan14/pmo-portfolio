---
import { getCollection } from 'astro:content';
import { PROFILE, SITE, SKILL_GROUPS, TOOLS } from '@/consts';
import QRCode from 'qrcode';

const projects = (await getCollection('projects'))
  .filter((p) => p.data.status === 'Public')
  .sort((a, b) => b.data.displayOrder - a.data.displayOrder);

const career = (await getCollection('career')).filter((c) => c.data.status === 'Public');
const byType = (t: string) =>
  career.filter((c) => c.data.type === t).sort((a, b) => b.data.displayOrder - a.data.displayOrder);
const employment = byType('Employment');
const committee = byType('Committee');
const education = byType('Education');

const period = (d: { startDate: string; endDate?: string; current?: boolean }) =>
  d.current ? `${d.startDate}〜現在` : d.endDate && d.endDate !== d.startDate ? `${d.startDate}〜${d.endDate}` : d.startDate;

const pPeriod = (s: string, e?: string) => (e ? `${s}〜${e}` : s);

const qrSvg = await QRCode.toString(SITE.url, { type: 'svg', margin: 0, width: 92 });
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>職務経歴書｜長南 貴則</title>
    <style>
      @page {
        size: A4;
        margin: 13mm 14mm;
      }
      * {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
        background: #fff;
        color: #1b2430;
        font-family: 'Yu Gothic', 'YuGothic', 'Meiryo', 'Noto Sans JP', sans-serif;
        font-size: 10.5px;
        line-height: 1.6;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      .sheet {
        max-width: 182mm;
        margin: 0 auto;
        padding: 8mm 0 12mm;
      }
      .rh {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
        border-bottom: 2px solid #102a4c;
        padding-bottom: 8px;
      }
      .rh h1 {
        margin: 0;
        font-size: 21px;
        color: #102a4c;
        letter-spacing: 0.04em;
      }
      .rh h1 span {
        font-size: 11px;
        font-weight: 600;
        color: #586374;
        margin-left: 8px;
        letter-spacing: 0.1em;
      }
      .rh__title {
        margin: 4px 0 0;
        font-weight: 700;
        font-size: 11px;
      }
      .rh__contact {
        margin: 3px 0 0;
        color: #586374;
        font-size: 10px;
      }
      .rh__qr {
        text-align: center;
        flex-shrink: 0;
      }
      .rh__qr svg {
        width: 46px;
        height: 46px;
        display: block;
        margin: 0 auto;
      }
      .rh__url {
        margin: 3px 0 0;
        font-size: 7.5px;
        color: #586374;
        letter-spacing: 0.01em;
      }
      h2.sec {
        font-size: 12px;
        color: #102a4c;
        margin: 16px 0 8px;
        padding: 3px 0 3px 9px;
        border-left: 4px solid #a87d3f;
        background: #f6f8fb;
      }
      p {
        margin: 0 0 6px;
      }
      .summary-tbl {
        width: 100%;
        border-collapse: collapse;
      }
      .summary-tbl th,
      .summary-tbl td {
        text-align: left;
        vertical-align: top;
        padding: 4px 8px;
        border-bottom: 1px solid #e4e8ee;
        font-weight: 400;
      }
      .summary-tbl th {
        width: 92px;
        color: #102a4c;
        font-weight: 700;
        white-space: nowrap;
      }
      .skills {
        display: flex;
        gap: 18px;
      }
      .skills__g {
        flex: 1;
      }
      .skills__g h3 {
        font-size: 10px;
        color: #102a4c;
        margin: 0 0 4px;
        border-bottom: 1px solid #d8e3f1;
        padding-bottom: 2px;
      }
      .skills__g ul {
        list-style: none;
        margin: 0;
        padding: 0;
        columns: 2;
      }
      .skills__g li {
        font-size: 9.5px;
        padding: 1px 0;
      }
      .skills__g li b {
        color: #a87d3f;
        margin-right: 4px;
      }
      .proj {
        border: 1px solid #e4e8ee;
        border-radius: 5px;
        padding: 8px 10px;
        margin: 0 0 8px;
        page-break-inside: avoid;
      }
      .proj h3 {
        margin: 0;
        font-size: 11px;
        color: #102a4c;
      }
      .proj h3 .yr {
        font-weight: 600;
        font-size: 9px;
        color: #586374;
        margin-left: 6px;
      }
      .proj__meta {
        margin: 2px 0 5px;
        font-size: 9px;
        color: #586374;
      }
      .proj__row {
        display: grid;
        grid-template-columns: 38px 1fr;
        gap: 6px;
        margin: 2px 0;
      }
      .proj__row .lb {
        font-size: 9px;
        font-weight: 700;
        color: #a87d3f;
        padding-top: 1px;
      }
      .proj__row ul {
        margin: 0;
        padding-left: 14px;
      }
      .proj__row li {
        font-size: 9.5px;
        line-height: 1.5;
      }
      .proj__row.res li {
        font-weight: 700;
      }
      .tl {
        margin: 0;
        padding: 0;
        list-style: none;
      }
      .tl li {
        display: grid;
        grid-template-columns: 130px 1fr;
        gap: 8px;
        padding: 4px 0;
        border-bottom: 1px solid #eef2f6;
      }
      .tl li .d {
        font-weight: 700;
        color: #102a4c;
        font-size: 9.5px;
      }
      .tl li .b strong {
        display: block;
        font-size: 10px;
      }
      .tl li .b span {
        color: #586374;
        font-size: 9px;
      }
      .pr h3 {
        font-size: 10.5px;
        margin: 8px 0 2px;
        color: #102a4c;
      }
      .pr p {
        font-size: 9.8px;
      }
    </style>
  </head>
  <body>
    <div class="sheet">
      <header class="rh">
        <div>
          <h1>長南 貴則 <span>CHONAN TAKANORI</span></h1>
          <p class="rh__title">統括PMO ／ 戦略PMO ／ クライシスマネジメント</p>
          <p class="rh__contact">{SITE.email}　｜　PMO実務歴 約10年</p>
        </div>
        <div class="rh__qr">
          <Fragment set:html={qrSvg} />
          <p class="rh__url">{SITE.url}</p>
        </div>
      </header>

      <h2 class="sec">職務要約</h2>
      <p>
        NTTドコモ（2007〜2023年・約16年）において、開発予算1兆円・体制2,000人規模のLTE全国展開をはじめ、全社横断システム導入・DX推進・新規事業開発の統括PMO／戦略PMOとして従事。その後フリーランスとして大手事業会社IT部門の管理PMOを約3年担当。「単なる進捗管理者」ではなく、CxOの右腕として機能する統括PMOを強みとし、「何を決めるべきか／誰をどう動かすか／どの順番で整理すべきか」を可視化して経営・現場・外部機関を横断しプロジェクトを前進させる。IPA専門委員・デジタル庁デジタル推進委員として国のガイドライン策定に参画。制度・法規制を踏まえた実行計画策定が差別化軸。
      </p>

      <h2 class="sec">PMOスキルサマリー</h2>
      <table class="summary-tbl">
        <tr><th>PMO実務</th><td>約10年（統括PMO／戦略PMO／リードPMO／管理PMO）</td></tr>
        <tr><th>最大案件</th><td>開発予算1兆円 ／ 体制2,000人 ／ 期間18ヶ月（LTE全国展開）</td></tr>
        <tr><th>対応業界</th><td>通信・金融・公共（自治体DX）／ 業界不問で対応可</td></tr>
        <tr><th>官公庁実績</th><td>総務省・経済産業省・IPA・デジタル庁との直接協働</td></tr>
        <tr><th>使用ツール</th><td>{TOOLS.join(' ／ ')}</td></tr>
      </table>

      <h2 class="sec">スキル・コンピテンシー（◎ 主担当 ／ ○ 経験あり ／ △ 補佐）</h2>
      <div class="skills">
        {
          SKILL_GROUPS.map((g) => (
            <div class="skills__g">
              <h3>{g.title}</h3>
              <ul>
                {g.items.map((it) => (
                  <li><b>{it.level}</b>{it.label}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

      <h2 class="sec">プロジェクト実績</h2>
      {
        projects.map((p) => {
          const d = p.data;
          return (
            <article class="proj">
              <h3>
                {d.title}
                <span class="yr">{pPeriod(d.durationStart, d.durationEnd)}</span>
              </h3>
              <p class="proj__meta">
                {[d.clientNameVisible, d.role, d.scope].filter(Boolean).join(' ／ ')}
              </p>
              <div class="proj__row">
                <span class="lb">課題</span>
                <ul>{d.challenge.map((x) => <li>{x}</li>)}</ul>
              </div>
              <div class="proj__row">
                <span class="lb">介入</span>
                <ul>{d.intervention.map((x) => <li>{x}</li>)}</ul>
              </div>
              <div class="proj__row res">
                <span class="lb">成果</span>
                <ul>
                  {d.resultsQuantitative.map((x) => <li>{x}</li>)}
                  {d.resultsQualitative.map((x) => <li>{x}</li>)}
                </ul>
              </div>
            </article>
          );
        })
      }

      <h2 class="sec">委員・外部活動</h2>
      <ul class="tl">
        {
          committee.map((c) => (
            <li>
              <span class="d">{period(c.data)}</span>
              <span class="b">
                <strong>{c.data.position ?? c.data.title}</strong>
                <span>{c.data.organization}</span>
              </span>
            </li>
          ))
        }
      </ul>

      <h2 class="sec">学歴</h2>
      <ul class="tl">
        {
          education.map((c) => (
            <li>
              <span class="d">{period(c.data)}</span>
              <span class="b">
                <strong>{c.data.position ?? c.data.title}</strong>
                <span>{c.data.organization}</span>
              </span>
            </li>
          ))
        }
      </ul>

      <h2 class="sec">自己PR</h2>
      <div class="pr">
        <h3>信条 ── 目的からの逸脱を許さないファシリテーション</h3>
        <p>
          声の大きさではなく「目的にとって最も大事かどうか」で判断する。会議のたびにプロジェクトのGOALを全体へ提示し、立場の上下や声の大小に迎合せず、毅然と臨む。一方で、周りに押し付けず、自分を持ち続ける。
        </p>
        <h3>強み ── 上流〜下流・制度まで見通す全体知</h3>
        <p>
          要件の上流から運用の下流、そして法制度まで。全体像と“つながり”を把握しているからこそ、問題が起きても根本から対処できる。数兆円規模のインフラ導入から重大インシデントの火消し、金融水準の厳格な移行まで、実現可能な戦略を立案し定着まで導いてきた。
        </p>
        <h3>提供価値 ── 任せれば、完遂する</h3>
        <p>
          依頼された作業を表面でこなすのではなく、その先の「目的への貢献」まで含めて完遂し、期限内に必ず完了報告がある。経営層とPMが安心して任せられるPMOを、即戦力で提供する。
        </p>
      </div>
    </div>
  </body>
</html>
