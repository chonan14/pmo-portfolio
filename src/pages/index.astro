---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import SkillsMatrix from '@/components/SkillsMatrix.astro';
import Voices from '@/components/Voices.astro';
import { Image } from 'astro:assets';
import portrait from '@/assets/portrait.jpg';
import { getCollection } from 'astro:content';
import { PROFILE, STATS, STRENGTHS, POSITIONING, VALUE_PROP, SEEKING, HIGHLIGHTS } from '@/consts';

const projects = (await getCollection('projects')).filter((p) => p.data.status === 'Public');
const featured = projects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.displayOrder - a.data.displayOrder)
  .slice(0, 3);
const projectCount = projects.length;
---

<BaseLayout>
  <section class="hero">
    <div class="container-wide hero__inner">
      <div class="hero__text">
        <p class="hero__eyebrow">{PROFILE.pmoYears}</p>
        <h1 class="hero__name">
          {PROFILE.fullName}<span class="hero__name-en">{PROFILE.fullNameEn}</span>
        </h1>
        <p class="hero__title">{PROFILE.title}</p>
        <p class="hero__catch">{PROFILE.catchphrase}</p>
        <p class="hero__lead">{PROFILE.lead}</p>
        <ul class="hero__highlights">
          {HIGHLIGHTS.map((h) => <li>{h}</li>)}
        </ul>
        <div class="hero__cta">
          <a href="/projects/" class="btn-primary">実績・ケーススタディを見る</a>
          <a href="/chonan-takanori-resume.pdf" class="btn-ghost">職務経歴書 PDF</a>
          <a href="/career/" class="btn-ghost">職務経歴</a>
        </div>
      </div>
      <div class="hero__media">
        <div class="hero__photo-frame">
          <Image
            src={portrait}
            alt={`${PROFILE.fullName} ポートレート`}
            widths={[420, 840]}
            sizes="(max-width: 900px) 64vw, 420px"
            class="hero__photo"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="vp">
    <div class="container-default vp__inner">
      <p class="section-eyebrow vp__eyebrow">Value</p>
      <p class="vp__headline pull-quote">{VALUE_PROP.headline}</p>
      <p class="vp__body">{VALUE_PROP.body}</p>
    </div>
  </section>

  <section class="stats">
    <div class="container-wide">
      <dl class="stats__grid">
        {
          STATS.map((s) => (
            <div class="stats__item">
              <dt>{s.value}</dt>
              <dd>{s.label}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <section class="section">
    <div class="container-wide">
      <header class="section__head">
        <p class="section-eyebrow">Strengths</p>
        <h2 class="section__title">4つの強み</h2>
        <p class="section__desc">{POSITIONING}</p>
      </header>
      <div class="strengths">
        {
          STRENGTHS.map((s) => (
            <article class="strength">
              <p class="strength__eyebrow">{s.eyebrow}</p>
              <h3 class="strength__title">{s.title}</h3>
              <p class="strength__body">{s.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container-wide">
      <header class="section__head">
        <p class="section-eyebrow">Case Studies</p>
        <h2 class="section__title">代表的な実績</h2>
        <p class="section__desc">
          国家インフラ規模の展開から危機対応、官民連携まで。全{projectCount}件を掲載しています。
        </p>
      </header>
      <div class="cards">
        {featured.map((p) => <ProjectCard project={p} />)}
      </div>
      <div class="section__more">
        <a href="/projects/" class="btn-ghost">すべての実績を見る（{projectCount}件）</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-default">
      <header class="section__head">
        <p class="section-eyebrow">Competency</p>
        <h2 class="section__title">スキル・コンピテンシー</h2>
      </header>
      <SkillsMatrix />
    </div>
  </section>

  <section class="section section--soft">
    <div class="container-narrow">
      <header class="section__head">
        <p class="section-eyebrow">Voice</p>
        <h2 class="section__title">現場で頂いた言葉</h2>
      </header>
      <Voices />
    </div>
  </section>

  <section class="section">
    <div class="container-default">
      <header class="section__head">
        <p class="section-eyebrow">Engagement</p>
        <h2 class="section__title">希望する関わり方</h2>
      </header>
      <dl class="seeking">
        {
          SEEKING.map((s) => (
            <div class="seeking__row">
              <dt>{s.label}</dt>
              <dd>{s.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(180deg, var(--color-primary-50) 0%, var(--color-paper) 70%);
    border-bottom: 1px solid var(--color-rule);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1.3fr 0.8fr;
    gap: 3rem;
    align-items: center;
    padding-block: clamp(3rem, 7vw, 5rem);
  }

  .hero__eyebrow {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.14em;
    color: var(--color-accent);
    margin: 0;
  }

  .hero__name {
    margin: 0.75rem 0 0;
    font-size: clamp(2.4rem, 5.5vw, 3.6rem);
    letter-spacing: 0.04em;
    color: var(--color-primary);
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero__name-en {
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    color: var(--color-ink-soft);
  }

  .hero__title {
    margin: 0.75rem 0 0;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-ink);
    letter-spacing: 0.04em;
  }

  .hero__catch {
    margin: 1.75rem 0 0;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: clamp(1.35rem, 2.8vw, 1.9rem);
    line-height: 1.6;
    color: var(--color-primary);
    white-space: pre-line;
  }

  .hero__lead {
    margin: 1.5rem 0 0;
    max-width: 36rem;
    font-size: 0.98rem;
    line-height: 2;
    color: var(--color-ink-soft);
  }

  .hero__highlights {
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.5rem;
    max-width: 37rem;
  }

  .hero__highlights li {
    position: relative;
    padding-left: 1.4rem;
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--color-ink);
  }

  .hero__highlights li::before {
    content: '';
    position: absolute;
    left: 0.1rem;
    top: 0.55rem;
    width: 0.5rem;
    height: 0.5rem;
    background: var(--color-accent);
    border-radius: 2px;
    transform: rotate(45deg);
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
  }

  .hero__photo-frame {
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-card);
    overflow: hidden;
    border: 1px solid var(--color-rule);
    box-shadow: var(--shadow-card);
    background: var(--color-paper-soft);
  }

  .hero__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .vp {
    background: var(--color-primary);
    color: white;
  }

  .vp__inner {
    padding-block: clamp(3rem, 7vw, 4.5rem);
    text-align: center;
  }

  .vp__eyebrow {
    color: var(--color-accent-on-dark);
    justify-content: center;
  }

  .vp__eyebrow::before {
    background: var(--color-accent-on-dark);
  }

  .vp__headline {
    margin: 1.25rem 0 0;
    font-size: clamp(1.9rem, 4.5vw, 2.9rem);
    color: white;
  }

  .vp__body {
    margin: 1.5rem auto 0;
    max-width: 42rem;
    line-height: 2;
    color: rgba(255, 255, 255, 0.86);
  }

  .stats {
    padding-block: clamp(2.5rem, 5vw, 3.5rem);
    border-bottom: 1px solid var(--color-rule);
  }

  .stats__grid {
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .stats__item {
    text-align: center;
  }

  .stats__item dt {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1.1;
  }

  .stats__item dd {
    margin: 0.6rem 0 0;
    font-size: 0.78rem;
    color: var(--color-ink-soft);
    line-height: 1.6;
  }

  .section {
    padding-block: clamp(3.5rem, 8vw, 6rem);
  }

  .section--soft {
    background: var(--color-paper-soft);
  }

  .section__head {
    text-align: center;
    max-width: 44rem;
    margin: 0 auto 3rem;
  }

  .section__head .section-eyebrow {
    justify-content: center;
  }

  .section__title {
    margin: 1rem 0 0;
    font-size: clamp(1.6rem, 3.5vw, 2.25rem);
  }

  .section__desc {
    margin: 1.25rem 0 0;
    color: var(--color-ink-soft);
    line-height: 1.95;
  }

  .strengths {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .strength {
    padding: 1.75rem;
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
  }

  .strength__eyebrow {
    margin: 0;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: var(--color-accent);
  }

  .strength__title {
    margin: 0.6rem 0 0;
    font-size: 1.15rem;
    color: var(--color-primary);
  }

  .strength__body {
    margin: 0.75rem 0 0;
    font-size: 0.92rem;
    line-height: 1.95;
    color: var(--color-ink-soft);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .section__more {
    margin-top: 2.5rem;
    text-align: center;
  }

  .seeking {
    margin: 0;
    border-top: 1px solid var(--color-rule);
    max-width: 40rem;
    margin-inline: auto;
  }

  .seeking__row {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 1.5rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-rule);
  }

  .seeking__row dt {
    font-weight: 700;
    color: var(--color-primary);
    font-size: 0.9rem;
  }

  .seeking__row dd {
    margin: 0;
    color: var(--color-ink);
  }

  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .hero__media {
      max-width: 22rem;
    }
    .stats__grid {
      grid-template-columns: 1fr 1fr;
    }
    .cards {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .strengths {
      grid-template-columns: 1fr;
    }
    .seeking__row {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
