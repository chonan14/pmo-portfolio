---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import CTASection from '@/components/CTASection.astro';
import { getCollection } from 'astro:content';
import { PROFILE, STATS, STRENGTHS } from '@/consts';

const projects = (await getCollection('projects')).filter((p) => p.data.status === 'Public');
const featured = projects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.displayOrder - a.data.displayOrder)
  .slice(0, 3);
const projectCount = projects.length;
---

<BaseLayout>
  <section class="hero">
    <div class="hero__bg" aria-hidden="true"></div>
    <div class="container-wide hero__inner">
      <div class="hero__text">
        <p class="hero__role">{PROFILE.title}</p>
        <h1 class="hero__title">{PROFILE.catchphrase}</h1>
        <p class="hero__lead">{PROFILE.lead}</p>
        <div class="hero__cta">
          <a href="/projects/" class="btn-primary">実績・ケーススタディを見る</a>
          <a href="/contact/" class="btn-ghost">PMO相談（初回無料）</a>
        </div>
      </div>

      <aside class="hero__card" aria-label="プロフィール要点">
        <p class="hero__card-name">
          {PROFILE.fullName}<span>{PROFILE.fullNameReading}</span>
        </p>
        <p class="hero__card-company">{PROFILE.company}</p>
        <dl class="hero__stats">
          {
            STATS.map((s) => (
              <div class="hero__stat">
                <dt>{s.value}</dt>
                <dd>{s.label}</dd>
              </div>
            ))
          }
        </dl>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container-wide">
      <header class="section__head">
        <p class="section-eyebrow">Strengths</p>
        <h2 class="section__title">提供する4つの強み</h2>
        <p class="section__desc">
          単なる進捗管理者ではなく、CxOの右腕として「決める」を前進させます。
        </p>
      </header>
      <div class="strengths">
        {
          STRENGTHS.map((s) => (
            <article class="strength">
              <p class="strength__eyebrow">{s.eyebrow}</p>
              <h3 class="strength__title">{s.title}</h3>
              <p class="strength__body">{s.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container-wide">
      <header class="section__head">
        <p class="section-eyebrow">Case Studies</p>
        <h2 class="section__title">代表的な実績</h2>
        <p class="section__desc">
          国家インフラ規模の展開から危機対応、官民連携まで。全{projectCount}件のケースを掲載しています。
        </p>
      </header>
      <div class="cards">
        {featured.map((p) => <ProjectCard project={p} />)}
      </div>
      <div class="section__more">
        <a href="/projects/" class="btn-ghost">すべての実績を見る（{projectCount}件）</a>
      </div>
    </div>
  </section>

  <div class="container-wide cta-wrap">
    <CTASection />
  </div>
</BaseLayout>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-rule);
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background-image:
      radial-gradient(60% 55% at 82% -5%, rgba(163, 113, 247, 0.2) 0, transparent 60%),
      radial-gradient(45% 50% at 12% 8%, rgba(47, 129, 247, 0.16) 0, transparent 58%),
      radial-gradient(40% 45% at 65% 110%, rgba(247, 120, 186, 0.1) 0, transparent 60%),
      linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: auto, auto, auto, 56px 56px, 56px 56px;
    mask-image: radial-gradient(circle at 60% 25%, black 0, transparent 85%);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1.3fr 0.9fr;
    gap: 3rem;
    align-items: center;
    padding-block: clamp(3rem, 8vw, 5.5rem);
  }

  .hero__role {
    display: inline-block;
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--color-primary-400);
    background: rgba(47, 129, 247, 0.08);
    border: 1px solid var(--color-primary-100);
    padding: 0.4rem 0.9rem;
    border-radius: 9999px;
  }

  .hero__title {
    margin: 1.5rem 0 0;
    font-size: clamp(2rem, 4.8vw, 3.25rem);
    line-height: 1.4;
    letter-spacing: -0.01em;
    white-space: pre-line;
    background: linear-gradient(180deg, #ffffff 28%, #8b949e 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero__lead {
    margin: 1.5rem 0 0;
    max-width: 36rem;
    font-size: 1.02rem;
    line-height: 1.95;
    color: var(--color-ink-soft);
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.25rem;
  }

  .hero__card {
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: 2rem;
  }

  .hero__card-name {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--color-ink);
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .hero__card-name span {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-ink-soft);
    letter-spacing: 0.08em;
  }

  .hero__card-company {
    margin: 0.4rem 0 0;
    font-size: 0.85rem;
    color: var(--color-ink-soft);
  }

  .hero__stats {
    margin: 1.75rem 0 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-rule);
    border: 1px solid var(--color-rule);
    border-radius: 0.75rem;
    overflow: hidden;
  }

  .hero__stat {
    background: var(--color-paper);
    padding: 1rem;
    text-align: center;
  }

  .hero__stat dt {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1.2;
  }

  .hero__stat dd {
    margin: 0.4rem 0 0;
    font-size: 0.72rem;
    color: var(--color-ink-soft);
    line-height: 1.5;
  }

  .section {
    padding-block: clamp(3.5rem, 8vw, 6rem);
  }

  .section--soft {
    background: var(--color-paper-soft);
  }

  .section__head {
    text-align: center;
    max-width: 42rem;
    margin: 0 auto 3rem;
  }

  .section-eyebrow {
    justify-content: center;
  }

  .section__title {
    margin: 1rem 0 0;
    font-size: clamp(1.6rem, 3.5vw, 2.25rem);
  }

  .section__desc {
    margin: 1rem 0 0;
    color: var(--color-ink-soft);
    line-height: 1.9;
  }

  .strengths {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .strength {
    padding: 1.75rem;
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
  }

  .strength__eyebrow {
    margin: 0;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: var(--color-accent);
  }

  .strength__title {
    margin: 0.6rem 0 0;
    font-size: 1.15rem;
    color: var(--color-primary);
  }

  .strength__body {
    margin: 0.75rem 0 0;
    font-size: 0.92rem;
    line-height: 1.9;
    color: var(--color-ink-soft);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .section__more {
    margin-top: 2.5rem;
    text-align: center;
  }

  .cta-wrap {
    margin-block: clamp(3.5rem, 8vw, 6rem);
  }

  @media (max-width: 960px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .cards {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 720px) {
    .strengths {
      grid-template-columns: 1fr;
    }
    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>
