---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="ページが見つかりません" noindex={true}>
  <section class="nf">
    <div class="container-narrow nf__inner">
      <p class="nf__code">404</p>
      <h1 class="nf__title">ページが見つかりません</h1>
      <p class="nf__text">
        お探しのページは移動または削除された可能性があります。
      </p>
      <div class="nf__actions">
        <a href="/" class="btn-primary">ホームへ戻る</a>
        <a href="/projects/" class="btn-ghost">実績を見る</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf {
    padding-block: clamp(4rem, 12vw, 8rem);
    text-align: center;
  }
  .nf__code {
    font-family: var(--font-display);
    font-size: clamp(4rem, 12vw, 7rem);
    font-weight: 800;
    color: var(--color-primary-100);
    margin: 0;
    line-height: 1;
  }
  .nf__title {
    margin: 1rem 0 0;
    font-size: 1.6rem;
  }
  .nf__text {
    margin: 1rem 0 0;
    color: var(--color-ink-soft);
  }
  .nf__actions {
    margin-top: 2rem;
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
